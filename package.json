{
  "name": "space-mission-simulator",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "install:all": "npm install --prefix frontend && npm install && pip install -r backend/requirements.txt",
    "dev": "concurrently -n api,web -c blue,cyan \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --prefix frontend",
    "dev:api": "cd backend && python -m uvicorn app.main:app --reload --port 8100",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm run build --prefix frontend",
    "build:api": "cd backend && python -m compileall app -q",
    "test": "npm run test:api && npm run build:web",
    "test:api": "cd backend && python -m pytest tests -q",
    "seed": "cd backend && python -m scripts.seed_missions",
    "start:api": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8100",
    "preview:web": "npm run preview --prefix frontend",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "screenshot": "node scripts/capture-screenshot.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
